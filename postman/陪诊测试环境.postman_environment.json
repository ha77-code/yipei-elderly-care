{
  "id": "yipei-test-env",
  "name": "陪诊测试环境",
  "values": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "default",
      "description": "后端服务基础地址，按实际部署修改端口",
      "enabled": true
    },
    {
      "key": "userId",
      "value": "",
      "type": "default",
      "description": "【动态】登录后自动写入当前用户ID",
      "enabled": true
    },
    {
      "key": "customerId",
      "value": "4",
      "type": "default",
      "description": "【固定】测试客户ID - customer1（张三）",
      "enabled": true
    },
    {
      "key": "companionId",
      "value": "12",
      "type": "default",
      "description": "【固定】测试陪诊师用户ID - companion1（李陪诊 / sys_user.id）",
      "enabled": true
    },
    {
      "key": "adminId",
      "value": "17",
      "type": "default",
      "description": "【固定】测试管理员ID - admin1（系统管理员）",
      "enabled": true
    },
    {
      "key": "companionProfileId",
      "value": "1",
      "type": "default",
      "description": "【固定】陪诊师资料ID - companion_profile.id（不是sys_user.id）",
      "enabled": true
    },
    {
      "key": "requestId",
      "value": "",
      "type": "default",
      "description": "【动态】发布需求后自动写入 requestId",
      "enabled": true
    },
    {
      "key": "orderId",
      "value": "",
      "type": "default",
      "description": "【动态】创建订单后自动写入 orderId",
      "enabled": true
    },
    {
      "key": "userRole",
      "value": "",
      "type": "default",
      "description": "【动态】登录后自动写入当前角色（CUSTOMER/COMPANION/ADMIN）",
      "enabled": true
    },
    {
      "key": "token",
      "value": "",
      "type": "default",
      "description": "【预留】后续JWT版本的认证token，当前版本用 X-User-Id 头",
      "enabled": true
    }
  ],
  "_postman_variable_scope": "environment"
}